# M3 evidence pipeline — set the key for your configured provider (see config.yaml llm.provider).
DEEPSEEK_API_KEY=

# Alternative champion provider (set llm.provider: anthropic in config.yaml).
ANTHROPIC_API_KEY=

# Optional: NewsAPI provider for M3 retrieval (Google News RSS works without it).
NEWSAPI_KEY=

# Optional: FRED API for macro nowcast inputs (M5).
FRED_API_KEY=

# Optional: Metaculus API key for cross-venue signal (M7, Phase 9/10). Requires
# a Metaculus account -- anonymous access was removed as of 2026-07-03 (see
# api/metaculus.py). Even with a key, the numeric community-prediction field
# may be gated behind a further data-access tier; the adapter abstains cleanly
# when it's null rather than guessing. (Renamed from METACULUS_API_TOKEN in
# brief v1.9; the client also reads the old name for backward compatibility.)
METACULUS_API_KEY=

# Optional: Phase 18 dead-man heartbeat. Paste a healthchecks.io-class ping URL
# (free tier, no card required) to get emailed if the collector or the nightly
# backup job goes silent. Absent = feature is silently off.
HEARTBEAT_URL=

# Optional: pmxt API key, read ONLY by scripts/pmxt_router_scan.py -- its own
# separate Windows Scheduled Task (install-pmxt-scan-task.ps1), never by
# src/lab or anything the orchestrator runs (see Claude.md's tech-stack row /
# §12: pmxt is a trading SDK and this key can also authorize live trades, so
# it must stay out of this project's own runtime and dependency tree). Feeds
# M7's cross-venue candidate matching via pmxt's Router (cross-venue market
# clustering) -- lab.models.m7_crossvenue.verify_pmxt_candidates runs its own
# independent LLM check on every pair before anything reaches
# data/markets_map.yaml.
PMXT_API_KEY=
