# M3 evidence pipeline — set the key for your configured provider (see config.yaml llm.provider).
DEEPSEEK_API_KEY=

# Alternative champion provider (set llm.provider: anthropic in config.yaml).
ANTHROPIC_API_KEY=

# Optional: NewsAPI provider for M3 retrieval (Google News RSS works without it).
NEWSAPI_KEY=

# Optional: FRED API for macro nowcast inputs (M5).
FRED_API_KEY=
