# M3 evidence pipeline — set the key for your configured provider (see config.yaml llm.provider).
DEEPSEEK_API_KEY=

# Alternative champion provider (set llm.provider: anthropic in config.yaml).
ANTHROPIC_API_KEY=

# Optional: NewsAPI provider for M3 retrieval (Google News RSS works without it).
NEWSAPI_KEY=

# Optional: FRED API for macro nowcast inputs (M5).
FRED_API_KEY=

# Optional: Metaculus API key for cross-venue signal (M7, Phase 9/10). Requires
# a Metaculus account -- anonymous access was removed as of 2026-07-03 (see
# api/metaculus.py). Even with a key, the numeric community-prediction field
# may be gated behind a further data-access tier; the adapter abstains cleanly
# when it's null rather than guessing. (Renamed from METACULUS_API_TOKEN in
# brief v1.9; the client also reads the old name for backward compatibility.)
METACULUS_API_KEY=
